<body>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;!DOCTYPE html&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;html lang="en"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;head&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;meta charset="UTF-8"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;meta name="viewport" content="width=device-width, initial-scale=1.0"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;title&gt;Navigator AI&lt;/title&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&amp;family=Inter:wght@300;400;500&amp;display=swap" rel="stylesheet"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;style&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">*{box-sizing:border-box;margin:0;padding:0;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">body{font-family:'Inter',sans-serif;background:#0a0a0f;color:#e8e4d9;height:100vh;display:flex;flex-direction:column;overflow:hidden;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.header{padding:20px 28px;border-bottom:1px solid rgba(212,175,55,0.15);display:flex;align-items:center;gap:14px;background:#0d0d14;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.logo{width:38px;height:38px;border-radius:10px;background:#d4af37;display:flex;align-items:center;justify-content:center;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.logo svg{width:18px;height:18px;fill:#0a0a0f;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.brand{flex:1;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.brand h1{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:400;color:#f0e6c0;letter-spacing:.08em;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.brand p{font-size:11px;color:#6b6655;letter-spacing:.12em;text-transform:uppercase;margin-top:2px;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.status{display:flex;align-items:center;gap:6px;font-size:11px;color:#6b6655;letter-spacing:.06em;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.dot{width:6px;height:6px;border-radius:50%;background:#d4af37;animation:glow 2s ease-in-out infinite;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">@keyframes glow{0%,100%{opacity:1;}50%{opacity:.3;}}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.actions{display:flex;gap:8px;padding:14px 28px;background:#0d0d14;border-bottom:1px solid rgba(212,175,55,0.1);flex-wrap:wrap;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.act-btn{padding:7px 16px;border:1px solid rgba(212,175,55,0.25);border-radius:20px;background:transparent;color:#b8a97a;font-size:12px;font-family:'Inter',sans-serif;cursor:pointer;letter-spacing:.04em;transition:all .2s;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.act-btn:hover{border-color:rgba(212,175,55,0.6);color:#d4af37;background:rgba(212,175,55,0.06);}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.messages{flex:1;overflow-y:auto;padding:24px 28px;display:flex;flex-direction:column;gap:16px;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.messages::-webkit-scrollbar{width:4px;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.messages::-webkit-scrollbar-thumb{background:rgba(212,175,55,0.2);border-radius:2px;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.msg{display:flex;gap:12px;align-items:flex-start;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.msg.user{flex-direction:row-reverse;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.av{width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;flex-shrink:0;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.av.ai{background:rgba(212,175,55,0.12);color:#d4af37;border:1px solid rgba(212,175,55,0.25);}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.av.user{background:#d4af37;color:#0a0a0f;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.bubble{max-width:82%;padding:12px 16px;font-size:13.5px;line-height:1.65;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.msg.ai .bubble{background:#13131e;border:1px solid rgba(212,175,55,0.12);border-radius:2px 14px 14px 14px;color:#c8c0a8;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.msg.user .bubble{background:rgba(212,175,55,0.1);border:1px solid rgba(212,175,55,0.25);border-radius:14px 2px 14px 14px;color:#e8ddb8;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.typing{display:none;gap:5px;align-items:center;padding:12px 16px;background:#13131e;border:1px solid rgba(212,175,55,0.12);border-radius:2px 14px 14px 14px;width:fit-content;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.typing.show{display:flex;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.tdot{width:5px;height:5px;border-radius:50%;background:#d4af37;opacity:.4;animation:td .9s infinite;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.tdot:nth-child(2){animation-delay:.15s;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.tdot:nth-child(3){animation-delay:.3s;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">@keyframes td{0%,80%,100%{transform:translateY(0);opacity:.4;}40%{transform:translateY(-5px);opacity:1;}}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.input-area{padding:16px 28px;background:#0d0d14;border-top:1px solid rgba(212,175,55,0.15);}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.input-row{display:flex;gap:10px;align-items:flex-end;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">textarea{flex:1;background:#13131e;border:1px solid rgba(212,175,55,0.2);border-radius:12px;padding:11px 16px;font-size:13.5px;font-family:'Inter',sans-serif;color:#e8e4d9;resize:none;outline:none;min-height:44px;max-height:100px;line-height:1.5;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">textarea::placeholder{color:#4a4538;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">textarea:focus{border-color:rgba(212,175,55,0.5);}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.send{width:44px;height:44px;border-radius:50%;background:#d4af37;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:opacity .2s;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.send:hover{opacity:.85;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.send:disabled{opacity:.3;cursor:not-allowed;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.send svg{fill:#0a0a0f;width:16px;height:16px;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.hint{font-size:11px;color:#3a3528;margin-top:8px;text-align:center;letter-spacing:.04em;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.divider{display:flex;align-items:center;gap:10px;margin:4px 0;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.divider span{font-size:10px;color:#3a3528;letter-spacing:.1em;text-transform:uppercase;}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">.divider::before,.divider::after{content:'';flex:1;height:1px;background:rgba(212,175,55,0.08);}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;/style&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;/head&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;body&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;div class="header"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;div class="logo"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;svg viewBox="0 0 24 24"&gt;&lt;path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/&gt;&lt;/svg&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;div class="brand"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;h1&gt;Navigator AI&lt;/h1&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;p&gt;Autonomous task agent&lt;/p&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;div class="status"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;div class="dot"&gt;&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>Online</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;div class="actions"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;button class="act-btn" onclick="quickSend('Book me a flight from Chennai to Delhi next Friday, cheapest economy')"&gt;✈ Flight&lt;/button&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;button class="act-btn" onclick="quickSend('Book a Rapido auto to Chennai Central Railway Station')"&gt;⟳ Rapido&lt;/button&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;button class="act-btn" onclick="quickSend('Check if I am eligible for PM Kisan Samman Nidhi and apply if eligible')"&gt;⊕ Govt scheme&lt;/button&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;button class="act-btn" onclick="quickSend('Pay my electricity bill online')"&gt;⚡ Pay bill&lt;/button&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;button class="act-btn" onclick="quickSend('Book 2 movie tickets for tonight at a nearby theatre')"&gt;◈ Movies&lt;/button&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;button class="act-btn" onclick="quickSend('Order groceries for the week from nearest delivery app')"&gt;⊞ Groceries&lt;/button&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;div class="messages" id="messages"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;div class="divider"&gt;&lt;span&gt;Today&lt;/span&gt;&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;div class="msg ai"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;div class="av ai"&gt;N&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;div class="bubble"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">      </span>Welcome. I am your Navigator AI — a personal agent that handles digital tasks on your behalf.&lt;br&gt;&lt;br&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">      </span>Tell me what you need done. I will plan every step and execute it for you.&lt;br&gt;&lt;br&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">      </span>&lt;span style="color:#6b6655;font-size:12px;"&gt;Flights · Cabs · Government schemes · Bills · Bookings&lt;/span&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;div style="padding:0 28px 6px;display:none;" id="typingRow"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;div style="display:flex;gap:12px;align-items:flex-start;"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;div class="av ai"&gt;N&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;div class="typing show" id="typing"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">      </span>&lt;div class="tdot"&gt;&lt;/div&gt;&lt;div class="tdot"&gt;&lt;/div&gt;&lt;div class="tdot"&gt;&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;div class="input-area"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;div class="input-row"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;textarea id="input" rows="1" placeholder="What would you like me to do..."</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">      </span>onkeydown="if(event.key==='Enter'&amp;&amp;!event.shiftKey){event.preventDefault();sendMessage()}"</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">      </span>oninput="this.style.height='auto';this.style.height=Math.min(this.scrollHeight,100)+'px'"&gt;&lt;/textarea&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;button class="send" id="sendBtn" onclick="sendMessage()"&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">      </span>&lt;svg viewBox="0 0 24 24"&gt;&lt;path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/&gt;&lt;/svg&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>&lt;/button&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>&lt;div class="hint"&gt;Navigator AI · Powered by LLaMA · Always confirms before payment&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;/div&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;script&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">const history=[];let busy=false;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">const SYSTEM=`You are Navigator AI — a premium autonomous task agent that handles real-world digital tasks for users with precision and elegance. When a user gives you a task: 1. Acknowledge confidently 2. Give a numbered step-by-step action plan 3. Specify exact websites/apps for each step 4. List any info needed from the user 5. Mention eligibility checks where relevant 6. Always confirm before payment or irreversible action. Use real Indian websites: MakeMyTrip, IRCTC, Rapido, pmkisan.gov.in, DigiLocker etc.`;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">function quickSend(t){document.getElementById('input').value=t;sendMessage();}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">function addMsg(role,text){</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>const m=document.getElementById('messages');</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>const d=document.createElement('div');</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>d.className='msg '+role;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>d.innerHTML=`&lt;div class="av ${role}"&gt;${role==='ai'?'N':'U'}&lt;/div&gt;&lt;div class="bubble"&gt;${text.replace(/\n/g,'&lt;br&gt;').replace(/\*\*(.*?)\*\*/g,'&lt;b&gt;$1&lt;/b&gt;')}&lt;/div&gt;`;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>m.appendChild(d);m.scrollTop=m.scrollHeight;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">function setTyping(on){</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>document.getElementById('typingRow').style.display=on?'block':'none';</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>document.getElementById('sendBtn').disabled=on;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>busy=on;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>document.getElementById('messages').scrollTop=9999;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">async function sendMessage(){</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>const inp=document.getElementById('input');</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>const text=inp.value.trim();</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>if(!text||busy)return;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>inp.value='';inp.style.height='auto';</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>addMsg('user',text);</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>history.push({role:'user',parts:[{text}]});</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>setTyping(true);</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>try{</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>const r=await fetch('/api/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({history,system:SYSTEM})});</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>const data=await r.json();</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>const reply=data.reply||'Unable to process that request.';</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>history.push({role:'model',parts:[{text:reply}]});</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>setTyping(false);addMsg('ai',reply);</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>}catch(e){</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">    </span>setTyping(false);addMsg('ai','Connection error. Please try again.');</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1"><span class="Apple-converted-space">  </span>}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">}</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;/script&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;/body&gt;</span></h1>
<h1 style="margin: 0.0px 0.0px 0.0px 0.0px; font: 18.0px Arial; color: #ffffff; -webkit-text-stroke: #ffffff; background-color: #175ae2"><span class="s1">&lt;/html&gt;</span></h1>
</body>
</html>
